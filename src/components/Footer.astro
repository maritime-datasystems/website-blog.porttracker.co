---
const today = new Date();
---

<footer>
	<div class="footer-content">
		&copy; {today.getFullYear()} Navisense GmbH. All rights reserved.
		<div class="links">
			<a href="https://navisense.de">Navisense</a>
			<a href="https://porttracker.co">PortTracker Dashboard</a>
			<a href="https://navisense.de/contact">Imprint</a>
		</div>
	</div>
</footer>
<style>
	footer {
		padding: 3em 1em;
		background: rgb(var(--black));
		color: rgba(255, 255, 255, 0.8);
		text-align: center;
		font-size: 0.9rem;
		margin-top: 4rem;
	}
	.footer-content {
		max-width: 960px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1rem;
	}
	.links {
		display: flex;
		gap: 1.5rem;
	}
	.links a {
		color: rgba(255, 255, 255, 0.9);
		text-decoration: none;
		transition: color 0.2s;
	}
	.links a:hover {
		color: var(--accent);
	}
</style>

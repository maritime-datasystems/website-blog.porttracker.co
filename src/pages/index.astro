---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
			}
			.hero {
				text-align: center;
				padding: 4rem 1rem;
				background: linear-gradient(135deg, rgba(11, 58, 66, 0.95), rgba(11, 58, 66, 0.85));
				color: white;
				border-radius: 12px;
				margin-bottom: 4rem;
				box-shadow: 0 4px 20px rgba(0,0,0,0.1);
			}
			.hero h1 {
				color: white;
				font-size: 3rem;
				margin-bottom: 1rem;
			}
			.hero p {
				font-size: 1.25rem;
				color: rgba(255, 255, 255, 0.9);
				max-width: 600px;
				margin: 0 auto;
			}
			ul {
				display: flex;
				flex-wrap: wrap;
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: calc(50% - 1rem);
				background: white;
				border-radius: 12px;
				box-shadow: 0 2px 8px rgba(0,0,0,0.05);
				transition: transform 0.2s ease, box-shadow 0.2s ease;
				overflow: hidden;
			}
			ul li:hover {
				transform: translateY(-4px);
				box-shadow: 0 8px 16px rgba(0,0,0,0.1);
			}
			ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			ul li:first-child {
				width: 100%;
				margin-bottom: 1rem;
				text-align: center;
			}
			ul li:first-child img {
				width: 100%;
				max-height: 400px;
				object-fit: cover;
			}
			ul li:first-child .title {
				font-size: 2.369rem;
			}
			ul li img {
				margin-bottom: 0.5rem;
				border-radius: 12px 12px 0 0;
				height: 250px;
				object-fit: cover;
				width: 100%;
				display: block;
			}
			.content-wrap {
				padding: 1.5rem;
			}
			ul li a {
				display: block;
			}
			.title {
				margin: 0 0 0.5rem 0;
				color: rgb(var(--black));
				line-height: 1.3;
			}
			.date {
				margin: 0;
				color: rgb(var(--gray));
				font-size: 0.9rem;
				font-weight: 500;
			}
			ul li a:hover h4,
			ul li a:hover .date {
				color: rgb(var(--accent));
			}
			@media (max-width: 720px) {
				ul {
					gap: 1em;
				}
				ul li {
					width: 100%;
					text-align: center;
				}
				ul li:first-child {
					margin-bottom: 0;
				}
				ul li:first-child .title {
					font-size: 1.563em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="hero">
				<h1>Welcome to PortTracker Blog</h1>
				<p>Your source for updates on maritime intelligence, vessel tracking features, and technical deep-dives.</p>
			</div>
			<section>
				<ul>
					{
						posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									{post.data.heroImage && (
										<img width={720} height={360} src={post.data.heroImage} alt="" />
									)}
									<div class="content-wrap">
										<h4 class="title">{post.data.title}</h4>
										<p class="date">
											<FormattedDate date={post.data.pubDate} />
										</p>
									</div>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
